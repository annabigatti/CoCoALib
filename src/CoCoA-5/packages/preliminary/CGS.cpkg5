enddefine; -- PrintNabe


define PrintExample(name, opt str)
  if not(IsDefined(str)) then str := ""; endif;
  line := sum(NewList(65-len(name),"-"));
  H := div(TimeOfDay(),100);
  if $.PrintFormat = "txt" then
    println "-- ", name, line," [", div(H,100), ":", mod(H,100), "] ", str,str,str,str,str;
  else // "latex"
    println "\\multicolumn{17}{|l|}{\\textbf{",name,"}} \\\\\\hline";
  endif;
enddefine; -- PrintExample


