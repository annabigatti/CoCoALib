--   endforeach;
--   return true;
-- enddefine; -- ContainsNone


-- define ByDimAndMult(I1, I2)
--   P := RingOf(I1);
--   d1 := dim(P/LT(I1));
--   d2 := dim(P/LT(I2));
--   if d1 = d2 then return multiplicity(P/LT(I1)) < multiplicity(P/LT(I2)); endif;
--   return d1 > d2;
-- enddefine; -- ByDimAndMult



define HasLowerDimOrContains(J1, J2)
  if IsOne(J1) then return true; endif;
  if IsOne(J2) then return false; endif;  
  dim1 := dim(RingOf(J1)/J1);
  dim2 := dim(RingOf(J2)/J2);
  if dim1 = dim2 then
    return IsContained_plus(J2,J1);
  endif;
  return dim1 < dim2;
enddefine; -- HasLowerDimOrContains

  
define HasLowerDim(J1, J2)
  -- if IsOne(J1) then println "impossible 1????"; return true; endif; 
  -- if IsOne(J2) then println "impossible 2????"; return false; endif;  
  -- if dim(RingOf(J1)/J1) = dim(RingOf(J2)/J2) then
  --   if  IsContained_plus(J2,J1) then    println "impossible 3????"; endif;
  --   return IsContained_plus(J2,J1);
  -- endif;
  return dim(RingOf(J1)/J1) < dim(RingOf(J2)/J2);
enddefine; -- HasLowerDim

  
define ChooseVanishing(ref ToDo, ref done)
//  IsVERBOSE := IsVERBOSE_func("ChooseVanishing");
  // All ideals have GB  (except starting ideal(0))
  t0:=CpuTime();
// meglio con o senza?
//  SortBy(ref ToDo, $.HasLowerDimOrContains);  -- *** SortByDimension 2021-10-15 ***
  SortBy(ref ToDo, $.HasLowerDim);  -- *** SortByDimension 2023-08-29 ***
//  println "ToDo = ", ToDo;
  aa := last(ToDo);
  remove(ref ToDo, len(ToDo));
  append(ref done, aa);
//  if IsVERBOSE($.VL_list) then println "--->  aa = ", aa; endif;
//  $.time_extra := $.time_extra + CpuTime() - t0;
//  incr(ref $.count_extra);
  return aa;
enddefine; -- ChooseVanishing


define MBLPP_X(G, ProdX)
//  println "LPP_X(g, ProdX) = ", interreduced([LPP_X(g, ProdX) | g in G]);
  X := ([LPP_X(g, ProdX) | g in G and not(IsCoprime(LPP(g), ProdX))]);
  return interreduced(X);
enddefine; -- MBLPP_X


define LC_Gpj(MB, G, ProdX)
//  MB := MBLPP_X_plus(G, ProdX);
  L := [ ideal([radical_plus(LC_X(g, ProdX)) | g in G and LPP_X(g, ProdX) = pp]) | pp in MB];
//  L := [ -- 2021-11-19 without radical --> terrible
  return L;
  //  return [ I in L | not(IsOne(I)) ];
enddefine; -- LC_Gpj

  
define VERBOSE(level, fn, obj1, obj2)
  if VerbosityLevel()>=level then println fn, obj1, obj2; endif;
enddefine; -- VERBOSE
  
--==== auxiliary end ====-  

/// H := radical(product(LCg_notKA, one(K_AX))); --> square-free VERY expensive!

define MINIMALIZED(L) -- L list of ideal in K[A]
  foreach Ia in L do
    noprint := ReducedGBasis_KA_plus(Ia);
  endforeach;
  Lsort := SortedBy(MakeSet(L), $.HasLowerDimOrContains);
  Lmin := [];
  for i := len(Lsort) to 1 step -1 do
    if ContainsNone(Lsort[i], Lmin) then
      append(ref Lmin, Lsort[i]);
    endif;
  endfor;
  return Lmin;
enddefine; -- MINIMALIZED


define RadGensIdeal(I)
  return ideal(RingOf(I), [radical_plus(g) | g in gens(I)]);
enddefine; -- RadGensIdeal
  

--====  core iterative  ====--
--==  do NOT modify the original ==--
  
define CGSCoreIter(I,X) // after Nabeshima
  IsVERBOSE := IsVERBOSE_func("CGSCoreIter");
  TIMER := 0;
  K_AX := RingOf(I); -- K[A,X];
  ProdX := product(X);
  -- initialization ----------------
  VanishingToDo := [ideal(K_AX, [])];
  ZeroCasesDone := [];
  CGS := [];
  -- main loop ----------------------
  while not(IsEmpty(VanishingToDo)) do
    --< Step 2.1 >--
    aa := ChooseVanishing(ref VanishingToDo, ref ZeroCasesDone);
    if IsVERBOSE($.VL_base) then println "-- iteration with aa = ", aa, " --"; endif;
    --< Step 2.2 >--
    J := I + aa;
    --< Step 2.3 >--
    G := ReducedGBasis_KAX_plus(J); -- G <-- RGB_J;
    --< Step 2.4 >-- -- g in K[A] -------
    RadGens := [radical_plus(g) | g in G and IsCoprime(LT(g), ProdX)];
    gg_RadGens := ideal(RingOf(I), RadGens);
    if IsVERBOSE($.VL_list) then println "gg_RadGens = ", gg_RadGens; endif;
    --< Step 2.5 >----------------------------------------------------------------
    if not(IsEmptyDiffVanishing_plus(aa, gg_RadGens)) then
      --< Step 2.5.1 >--
      if IsVERBOSE($.VL_base) then println "  -- V(aa)\\V(gg) non empty"; endif;
      append(ref CGS, record[Is0:=aa,
			     IsNot0:=[ideal(g) | g in RadGens],
			     GB:=[one(K_AX)]]); // CGS1
      --< Step 2.5.2 >--
      if ContainsNone(gg_RadGens, VanishingToDo) then
	if IsVERBOSE($.VL_base) then println "  --new gg_RadGens contains none (appended)"; endif;	
	append(ref VanishingToDo, gg_RadGens);
      else
	if IsVERBOSE($.VL_base) then println "  --new gg_RadGens contains some (removed)"; endif;	
      endif;
    --< Step 2.6 >----------------------------------------------------------------
    else
      --< Step 2.6.1 >--
      MB := MBLPP_X_plus(G, ProdX);
      if IsVERBOSE($.VL_list) then println "MB = ", MB; endif;
      t0 := CpuTime();
      --< Step 2.6.2 >--
      G_MB := [ g in G | not(IsCoprime(LT(g), ProdX))
	       and LPP_X(g, ProdX) isin MB ];
      --< Step 2.6.3 >--
      LC_MB := LC_Gpj(MB, G_MB, ProdX); -- [ RadGensIdeal(cc_t) | t in MB ]
      LC_MB := [cc_t in LC_MB | not(1 isin gens(cc_t))]; -- not(IsOne(J)) -- MOLTO COSTOSO per P3P
      ---->  LC_MB := MINIMALIZED(LC_MB); -- non conviene: calcolo GB(J) poi inutile
      TIMER := TIMER + CpuTime() - t0;
      if IsVERBOSE($.VL_list) then println "LC_MB = ", LC_MB; endif;
      --< Step 2.6.4 >--
      append(ref CGS, record[Is0:=gg_RadGens, IsNot0:=LC_MB, GB:=G_MB]); // CGS2
      --< Step 2.6.5 >--  -- start NewVanishing ------------
      NoPrint := ReducedGBasis_KA_plus(gg_RadGens);  // to separate GB timing
///      NewVanishing := MINIMALIZED([ RadGensIdeal(cc_t) + gg_RadGens
      NewVanishing := MINIMALIZED([ cc_t + gg_RadGens
				   | cc_t in LC_MB and not(IsContained_plus(cc_t, gg_RadGens)) ]);
      if IsVERBOSE($.VL_list) then println "NewVanishing = ", NewVanishing; endif;
      if NewVanishing<>[] and IsOne(NewVanishing[1]) then
      if IsVERBOSE($.VL_base) then println " --skip (1)"; endif;
	NewVanishing:=[];
      endif;
      --< Step 2.6.6 >--
      foreach bb in NewVanishing do
	//      NoPrint := ReducedGBasis_KA_plus(bb);  // GB computed in MINIMALIZZA
	if ContainsNone(bb, VanishingToDo) then -- tengo ideali piu' piccoli
	  if IsVERBOSE($.VL_list) then println "  keep "+sprint(bb); endif;	
	  append(ref VanishingToDo, bb);
	else
	  if IsVERBOSE($.VL_list) then println "  delete "+sprint(bb), ""; endif;
	  If IsVERBOSE($.VL_base) then println "    --contains some in VanishingToDo"; endif;
	endif;
      endforeach;
    endif;    
    if IsVERBOSE($.VL_base) then println "-- end iteration: ", len(VanishingToDo), " case(s) left "; endif;
    if IsVERBOSE($.VL_list) then println "  --==> VanishingToDo = --vvvv--"; indent(VanishingToDo); endif;
  endwhile;
//  println "TIMER ",DecimalStr(TIMER,1);
  return CGS;
enddefine; -- CGSCoreIter

  
--=================================================--
--==   modify only below, not the original above ==--
--====  core iterative 2026  ====--
  
define CGSCoreIter2026(I,X)
  IsVERBOSE := IsVERBOSE_func("CGSCoreIter2026");
  TIMER := 0;
  K_AX := RingOf(I); -- K[A,X];
  ProdX := product(X);
  -- initialization --2026--------------
  VanishingToDo := [ideal(K_AX, [])];
  ZeroCasesDone := [];
  CGS := [];
  -- main loop --2026--------------------
  while not(IsEmpty(VanishingToDo)) do
    --< Step 2.1 >--
    aa := ChooseVanishing(ref VanishingToDo, ref ZeroCasesDone);
    if IsVERBOSE($.VL_base) then println "-- iteration with aa = ", aa, " --------"; endif;
    --< Step 2.2 >--
    J := I + aa;
    --< Step 2.3 >--
    G := ReducedGBasis_KAX_plus(J); -- G <-- RGB_J;
    --< Step 2.4 >-- -- g in K[A] -------
    gg_list := [g in G | IsCoprime(LT(g), ProdX)];
    gg_RadGens := ideal(RingOf(I), [radical_plus(g) | g in gg_list ]);
    // 2026 -- se diversi, metto in VanishingToDo?
    if IsVERBOSE($.VL_list) then println "gg_RadGens = ", gg_RadGens; endif;
    --< Step 2.5 >--2026--------------------------------------------------------------
    if not(IsEmptyDiffVanishing_plus(aa, gg_RadGens)) then
      --< Step 2.5.1 >--
      if IsVERBOSE($.VL_base) then println "  -- V(aa)\\V(gg) non empty"; endif;
      append(ref CGS, record[Is0:=aa,
//			     IsNot0:=[ideal(g) | g in gg_list],
			     IsNot0:=[gg_RadGens], // 2026 - credo, ma sono confusa
			     GB:=[one(K_AX)]]); // CGS1
      --< Step 2.5.2 >--
// 2026 removed:     if ContainsNone(gg_RadGens, VanishingToDo) then
      if ContainsNone(ideal(gg_list), VanishingToDo) then
	if IsVERBOSE($.VL_base) then println "  --new gg_RadGens contains none (append gg to VanishingToDo)"; endif;	
	append(ref VanishingToDo, gg_RadGens);
	if IsVERBOSE($.VL_list) then println "--==> VanishingToDo = --vvvv--"; indent(VanishingToDo); endif;
      else
	if IsVERBOSE($.VL_base) then println "  --new gg_RadGens contains some (removed)"; endif;	
      endif;
    --< Step 2.6 >--2026--------------------------------------------------------------
    else
      if gg_list<>[] and ideal(gg_list) <> gg_RadGens and ContainsNone(ideal(gg_list), VanishingToDo) then
	if IsVERBOSE($.VL_list) then println "  gg_list = ", gg_list, "\n  gg_RadGens = ", gg_RadGens; endif;
	if IsVERBOSE($.VL_base) then println " (append gg to VanishingToDo)"; endif;
	append(ref VanishingToDo, gg_RadGens);
	if IsVERBOSE($.VL_list) then println "--==> VanishingToDo = --vvvv--"; indent(VanishingToDo); endif;
	continue; // 2026: added this if
      endif;      
      --< Step 2.6.1 >--
      MB := MBLPP_X_plus(G, ProdX);
      if IsVERBOSE($.VL_list) then println "        MB = ", MB; endif;
      t0 := CpuTime();
      --< Step 2.6.2 >--
      G_MB := [ g in G | not(IsCoprime(LT(g), ProdX))
	       and LPP_X(g, ProdX) isin MB ];
      --< Step 2.6.3 >--
      LC_MB := LC_Gpj(MB, G_MB, ProdX); -- [ RadGensIdeal(cc_t) | t in MB ]
      LC_MB := [cc_t in LC_MB | not(1 isin gens(cc_t))]; -- not(IsOne(J)) -- VERY COSTLY for ex-P3P
      ---->  LC_MB := MINIMALIZED(LC_MB); -- not convenient: computes GB(J) uselessly
      TIMER := TIMER + CpuTime() - t0;
      if IsVERBOSE($.VL_list) then println "     LC_MB = ", LC_MB; endif;
      --< Step 2.6.4 >--
      append(ref CGS, record[Is0:=gg_RadGens, IsNot0:=LC_MB, GB:=G_MB]); // CGS2
      --< Step 2.6.5 >--  -- start NewVanishing ------------
      NoPrint := ReducedGBasis_KA_plus(gg_RadGens);  // to separate GB timing
///      NewVanishing := MINIMALIZED([ RadGensIdeal(cc_t) + gg_RadGens
      NewVanishing := MINIMALIZED([ cc_t + gg_RadGens
				   | cc_t in LC_MB and not(IsContained_plus(cc_t, gg_RadGens)) ]);
      if IsVERBOSE($.VL_list) then println "NewVanishing = ", NewVanishing; endif;
      if NewVanishing<>[] and IsOne(NewVanishing[1]) then
      if IsVERBOSE($.VL_base) then println " --skip (1)"; endif;
	NewVanishing:=[];
      endif;
      --< Step 2.6.6 >--
      foreach bb in NewVanishing do
	// GB of bb computed in MINIMALIZED
	if ContainsNone(bb, VanishingToDo) then -- keep the smallest ideals
	  if IsVERBOSE($.VL_list) then println "  keep "+sprint(bb); endif;	
	  if IsVERBOSE($.VL_base) then println "    (append bb to VanishingToDo)"; endif;	
	  append(ref VanishingToDo, bb);
	else
	  if IsVERBOSE($.VL_list) then println "  delete "+sprint(bb), ""; endif;
	  If IsVERBOSE($.VL_base) then println "    --contains some in VanishingToDo"; endif;
	endif;
      endforeach;
    endif;    
    if IsVERBOSE($.VL_base) then println "-- end iteration: ", len(VanishingToDo), " case(s) left in VanishingToDo"; endif;
    if IsVERBOSE($.VL_list) then println "\n--==> VanishingToDo = --vvvv--"; indent(VanishingToDo); endif;
  endwhile;
//  println "TIMER ",DecimalStr(TIMER,1);
  return CGS;
enddefine; -- CGSCoreIter2026
  
