--   return L;
-- enddefine; -- SpecializeInXRing
  
define monic0(f)
  if f=0 then return f; else return monic(f); endif;
enddefine; -- monic0
  
define SpecializeInXRing(CGS, index, SubstIdeal, ideal2)
  segment := CGS.segments[index];
  P := RingOf(segment.Is0); -- K[A,X];
  phi := PolyAlgebraHom(RingOf(SubstIdeal), P, indets(P));
  SI_P := ideal(phi(gens(SubstIdeal)));
  phi := PolyAlgebraHom(RingOf(ideal2), P, indets(P));
  ideal2_P := ideal(phi(gens(ideal2)));
  J0 := segment.Is0 + SI_P + ideal2_P;
  if IsOne(J0) then
    error("inconsistent: " + sprint(GBasis(J0))+ "=0");
  endif;
  foreach s in segment.IsNot0 do
    if IsEmptyDiffVanishing_plus(J0, s) then
      error("inconsistent: " + sprint(GBasis(J0))+ "=0 and " +sprint(s) +"<>0");
    endif;
  endforeach;
  L := [ monic0(NF(f, J0)) | f in segment.GB ];
  return L;
enddefine; -- SpecializeInXRing


define FindSpecializedGB(CGS, SubstIdeal, opt ideal2)
  if not(IsDefined(ideal2)) then
    ideal2 := ideal(zero(RingOf(CGS.I)));
  endif;
  for i := 1 to len(CGS.segments) do
    print "segment ", i, ":  ";
    try      
      SIR := SpecializeInXRing(CGS, i, SubstIdeal, ideal2);
      indent(SIR);
    UponError E Do
      println GetErrMesg(E);
    endtry;
  endfor;
enddefine; -- FindSpecializedGB


define CleanupCGS(ref CGS)
  CleanedSegments := [];
  foreach s in CGS.segments do
    s.IsNot0 := [ IdealOfGBasis(I) | I in MINIMALIZED(s.IsNot0) ]; // 2026 Anna
    if s.IsNot0=[] or not(IsEmptyDiffVanishing_plus(s.Is0, product(s.IsNot0))) then
      append(ref CleanedSegments, s);
    endif;
  endforeach;
  CGS.segments := CleanedSegments;
enddefine; -- CleanupCGS
  
  
endpackage;


