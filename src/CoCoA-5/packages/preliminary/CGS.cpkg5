define LC_X(g, ProdX)
  t0 := CpuTime();
  LT_X := LPP_X(g, ProdX);
  XX := sum([m in monomials(g)  |  IsDivisible(m,LT_X)])/LT_X;
//  $.time_extra := $.time_extra + CpuTime() -t0;   incr(ref $.count_extra);
  return XX;
enddefine; -- LC_X


define LPP_X(g, ProdX)
  t0 := CpuTime();
  XX := gcd(LT(g), ProdX^deg(LT(g)));
//  $.time_extra := $.time_extra + CpuTime() -t0;   incr(ref $.count_extra);
  return XX;
enddefine; -- LPP_X


define CheckElimOrdering(K_AX, X)
  ProdA := product(indets(K_AX))/product(X);
  foreach x in X do
    -- cheat check! <<<--------------------
    if x < ProdA^100 then error("non elim ordering for "+sprint(x)); endif;
  endforeach;
  -- make proper check! <<<--------------------
enddefine; -- CheckElimOrdering


define ElimXElimZdrlA(NumParams, NumX)  -- [params, X] + elim Z := last(X)
  M := mat([
	    ConcatLists([NewList(NumParams, 0), NewList(NumX-1, 1), [0]]),
	    ConcatLists([NewList(NumParams, 0), NewList(NumX-1, 0), [1]]),
	    ConcatLists([NewList(NumParams, 1), NewList(NumX, 0)])  ]);
  return MakeTermOrdMat(M);
enddefine; -- ElimMatElimZdrl


define ElimXElimZdrl(NumParams, NumX)  -- [params, X] + elim Z := last(X)
  M := mat([
	    ConcatLists([NewList(NumX-1, 1), [0]]),
	    ConcatLists([NewList(NumX-1, 0), [1]])  ]);
  OrdX := MakeTermOrdMat(M);
  OrdParams := StdDegRevLexMat(NumParams);
  return BlockMat2x2(ZeroMat(RingZZ(),NumX,NumParams),  OrdX,
		     OrdParams,  ZeroMat(RingZZ(),NumParams,NumX));
enddefine; -- ElimMatElimZdrl


define ElimXLex(NumParams, NumX)  -- [params, X] + elim last(X)
  OrdX := LexMat(NumX);
  OrdParams := StdDegRevLexMat(NumParams);
  return BlockMat2x2(ZeroMat(RingZZ(),NumX,NumParams),  OrdX,
		     OrdParams,  ZeroMat(RingZZ(),NumParams,NumX));
enddefine; -- ElimXLex


define ElimXDRL(NumParams, NumX)  -- [params, X] + elim last(X)
  OrdX := StdDegRevLexMat(NumX);
  OrdParams := StdDegRevLexMat(NumParams);
  return BlockMat2x2(ZeroMat(RingZZ(),NumX,NumParams),  OrdX,
		     OrdParams,  ZeroMat(RingZZ(),NumParams,NumX));
enddefine; -- ElimXDRL


--==============================================================================
--==    ITER    ================================================================
--==============================================================================

define CGSIter(I,X, opt OrdMat)
  ResetGlobals();
  K_AX := RingOf(I); -- K[A,X];
  if IsDefined(OrdMat) then
    P := NewPolyRing(CoeffRing(K_AX), IndetSymbols(K_AX), OrdMat, 0);
    phi := PolyAlgebraHom(K_AX, P, indets(P));
    result := record[X := phi(X), I := ideal(phi(gens(I)))];
    result.segments := CGSCoreIter2026(result.I, result.X);
  else
    CheckElimOrdering(K_AX, X);
    result := record[X := X, I := I];
    result.segments := CGSCoreIter2026(result.I, result.X);
  endif;
  PrintGlobals("iter");
  return result;
enddefine; -- CGSIter
  

--==== auxiliary ====-
define ContainsNone(I, ListOfIdeals)
  noprint := ReducedGBasis_KA_plus(I);
  foreach J in ListOfIdeals do
    if IsContained_plus(J, I) then return false; endif;
  endforeach;
  return true;
enddefine; -- ContainsNone

