--       if f=g then print "="; endif;
--     endforeach;
--   endforeach;
  -- println count;
  return I*J;
//  return ideal(RingOf(I), []);
enddefine; -- ProdRad


define RoughCheck(Z, NZ, L)
  foreach I in L do
    Pr := ProdRad_plus(NZ,I);
    // Pr := ideal(RingOf(I), [radical_plus(f) | f in gens(Pr)]);
    // ^ good for some, very bad for some (N)
    t := CpuTime();
//    b := IsEmptyDiffVanishing_plus(Z, intersect(NZ, I)); -- before 2021-11-19
    b := IsEmptyDiffVanishing_plus(Z, Pr);  -- 2021-11-19
    if b then return 0; endif;
  endforeach;
  return 1;
enddefine; -- RoughCheck


--========  CORE NABESHIMA  ========--

define CGSCoreNabe(Z, NZ, I, ProdX, RecDepth) -- I ideal in K[A,X], X list of variables
IsVERBOSE := IsVERBOSE_func("CGSCoreNabe");
  if IsVERBOSE($.VL_list) then println "-- recursion with Z = ", Z, " --"; endif;
  if IsVERBOSE($.VL_list) then println "--               NZ = ", NZ, " --"; endif;
  t := CpuTime();
  b := IsEmptyDiffVanishing_plus(Z, NZ);
  if b and IsVERBOSE($.VL_base) then println "-- IsEmptyDiffVanishing is true"; endif;
  if b then return []; endif;  --> return
  G := ReducedGBasis_KAX_plus(I+Z);
////  if IsOne(I) then  -- in Iter facciamo un controllo diverso!! controlla (2021-10-6)
  -- if IsOne(G[1]) then  /// 2022-01-14    perche' IsOne(I)??? incluso in caso dopo
  --   if IsVERBOSE($.VL_base) then println "  --ideal(1) RecDepth=", RecDepth; endif;
  --   return [record[Is0:=Z, IsNot0:=NZ, GB:=G]];  --> return
  -- endif;
  --< [iter-Step 2.4] >-- -- g in K[A] -------
  RadGensKA := [radical_plus(g) | g in G and IsCoprime(LT(g), ProdX)];
  gg_RadGens := ideal(RingOf(I), RadGensKA);
  if IsVERBOSE($.VL_list) then println "RadGensKA = ", RadGensKA; endif;
  PGB := [];
//  Int_ginKA_NZ := ideal(RingOf(I), [rad(g) | g in gens(gg * NZ)]); -- before 2021-11-19
  Int_ginKA_NZ := ProdRad_plus(gg_RadGens, NZ); -- 2021-11-19
  b := IsEmptyDiffVanishing_plus(Z, Int_ginKA_NZ);
  if not(b) then
    PGB := [
	    record[Is0:=Z,
		   IsNot0:=concat([ideal(g)|g in RadGensKA],[NZ]),
		   GB:=[one(RingOf(I))]] ];
  endif;
  b := IsEmptyDiffVanishing_plus(gg_RadGens, NZ);
  if IsVERBOSE($.VL_base) then println "IsEmptyDiffVanishing(gg_RadGens, NZ) = ", b; endif;
  if b then return PGB; endif;  --> return: recursion stopped by IsEmptyDiffVanishing
  --< [iter-Step 2.6] >--------------------------------------------------------------
  MB := MBLPP_X_plus(G, ProdX);
  if IsVERBOSE($.VL_list) then println "MB = ", MB; endif;
  G_MB := [ g in G | not(IsCoprime(LT(g), ProdX))
	   and (LPP_X(g, ProdX) isin MB) ];
  LC_MB := LC_Gpj(MB, G_MB, ProdX); -- [ cc_t | t in MB ]
  LC_MB := [cc_t in LC_MB | not(1 isin gens(cc_t))]; -- not(IsOne(J)) -- MOLTO COSTOSO per P3P
  if IsVERBOSE($.VL_list) then println SprintRec(RecDepth)+"LC_MB = ", LC_MB; endif;
//  if false and IsOne(NZ) then NZ_set:=[];  -------------- cancellato
  if IsOne(gens(NZ)[1]) then NZ_set:=[];  -------------- cancellato
  else NZ_set:=[NZ]; endif;
//=== DISABLED ====> //
  if RoughCheck(Z, NZ, LC_MB)=1 then
//  if true then
    append(ref PGB, record[Is0:=gg_RadGens,
//			   IsNot0:=IntersectionList(concat([NZ], LC_MB)),
//			   IsNot0:=product(concat([NZ], LC_MB)),
///   commented 2024-02	   IsNot0:=concat(NZ_set, [II in LC_MB | not(IsOne(II))]),
///   commented 2024-03	   IsNot0:=concat(NZ_set, [II in LC_MB | not(1 IsIn gens(II))]),
			   IsNot0:=concat(NZ_set, LC_MB),
			   GB:=G_MB]);
  else
    if IsVERBOSE($.VL_base) then println "RoughCheck -- skip GBasis", ""; endif;
  endif;
  newNZ := NZ;
  foreach cc_t in LC_MB do
////    rg_cc_t := RadGensIdeal(cc_t);
    PGB := concat(PGB, CGSCoreNabe(Z+cc_t, newNZ, I, ProdX, RecDepth+1));
//    newNZ := ideal(RingOf(I), [ rad(g) | g in gens(newNZ * J)]); -- before 2021-11-19
    newNZ := ProdRad_plus(newNZ, cc_t); -- 2021-11-19   // square-free very expensive
  endforeach;
  return PGB;
enddefine; -- CGSCoreNabe



