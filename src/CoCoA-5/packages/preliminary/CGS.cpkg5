define ResetGlobals()
  $.time_t0 := CpuTime();
  $.count_extra := 0;
  $.time_extra := 0;
  $.count_ProdRad := 0;
  $.time_ProdRad := 0;
  $.count_radical := 0;
  $.time_radical := 0;
  $.count_sqfr := 0;
  $.time_sqfr := 0;
  $.count_GB_AX := 0;
  $.time_GB_AX := 0;
  $.count_GB_A := 0;
  $.time_GB_A := 0;
  $.count_IsContained := 0;
  $.time_IsContained := 0;
  $.count_IsEmptyDiffVanishing := 0;
  $.time_IsEmptyDiffVanishing := 0;
  $.count_MBLPP_X := 0;
  $.time_MBLPP_X := 0;
enddefine; -- ResetGlobals

//-------- printing timings/data ----------------------------------------
define FmtCount(str, X, NumSpaces)
  if $.PrintFormat = "txt" then
    if X=0 then return str +format("- ", NumSpaces) +" "; endif;
    return str +format(X, NumSpaces) +" ";
  endif;
  // else "latex"
  if X=0 then return " & " + format("- ", NumSpaces) +" "; endif;
  return " & " + format(X, NumSpaces) +" ";    
enddefine; -- FmtCount


define FmtTime(X, NumSpaces)
  if $.PrintFormat = "txt" then
    if X=0 then return format("- |", NumSpaces); endif;
    return format(DecimalStr(X,1), NumSpaces) +"s|";
  endif;
  // else "latex"
  if X=0 then return " & " + format("- ", NumSpaces); endif;
  return " & " + format(DecimalStr(X,1), NumSpaces) +"s";
enddefine; -- FmtTime


define PrintGlobals(fn)
  if VerbosityLevel()>=$.VL_time then
    if $.PrintFormat = "txt"      then    print "--",fn,"|";
    else    print fn;
    endif;
    print FmtCount("GB A,X",  $.count_GB_AX, 2), FmtTime($.time_GB_AX,4);
    print FmtCount("GB A",  $.count_GB_A, 2), FmtTime($.time_GB_A,4);
    print FmtCount("IsCont",$.count_IsContained,3), FmtTime($.time_IsContained,4);
    print FmtCount("ieDV",$.count_IsEmptyDiffVanishing,3), FmtTime($.time_IsEmptyDiffVanishing,4);
    print FmtCount("ProdRad", $.count_ProdRad,2), FmtTime($.time_ProdRad,4);
    print FmtCount("MB",$.count_MBLPP_X,3), FmtTime($.time_MBLPP_X,4);
//    print FmtCount("xtr", $.count_extra,2), FmtTime($.time_extra,3);
    print FmtCount("sqfr", $.count_sqfr,3), FmtTime($.time_sqfr,4);
//    print FmtCount("rad", $.count_radical,4), FmtTime($.time_radical,4);
  endif;
enddefine; -- PrintGlobals


define PrintLatexHeader()
  H := div(TimeOfDay(),100);
  println date(), " h ", div(H,100), ":", sum(["0"|i in 1..(1-FloorLog10(mod(H,100)))], ""), mod(H,100);
  println "-- {\\scriptsize comment}";
  println "\\noindent";
//  println "\\begin{tabular}{|l|rr|rr|rr|rr|rr|rr||rr|}";
  println "\\begin{tabular}{|l|r@{\\;\\;}r|r@{\\;\\;}r|r@{\\;\\;}r|r@{\\;\\;}r|r@{\\;\\;}r|r@{\\;\\;}r|r@{\\;\\;}r||r@{\\;\\;}r|}";
  println "\\hline";
  print "& \\multicolumn{2}{|c|}{GB in} ";
  print "& \\multicolumn{2}{|c|}{GB in} ";
  print "& \\multicolumn{2}{|c|}{check} ";
  print "& \\multicolumn{2}{|c|}{check ${=}\\emptyset$} ";
  println "& \\multicolumn{2}{|c|}{} ";
//    print FmtCount("xtr", $.count_extra,2), FmtTime($.time_extra,3);
  print "& \\multicolumn{2}{|c|}{} ";
//    print FmtCount("rad", $.count_radical,4), FmtTime($.time_radical,4);
  print "& \\multicolumn{2}{|c||}{} ";
  print "&  &  ";
  println "\\\\";
  print "& \\multicolumn{2}{|c|}{$K[A,X]$} ";
  print "& \\multicolumn{2}{|c|}{$K[A]$} ";
  print "& \\multicolumn{2}{|c|}{$\\mathfrak a\\subseteq \\mathfrak b$} ";
  print "& \\multicolumn{2}{|c|}{$\\Bbb V(\\mathfrak a)\\backslash \\Bbb V(\\mathfrak b)$} ";
  println "& \\multicolumn{2}{|c|}{ProdRad} ";
//    print FmtCount("xtr", $.count_extra,2), FmtTime($.time_extra,3);
  print "& \\multicolumn{2}{|c|}{MB} ";
//    print FmtCount("rad", $.count_radical,4), FmtTime($.time_radical,4);
  print "& \\multicolumn{2}{|c||}{sqfr} ";
  print "& \\# & time ";
  println "\\\\\\hline";
enddefine; -- PrintLatexHeader

//-- more about printing timings/data: ----------------------------------------
//-- "plus" means tracking for time and counts --------------------------------
  
define ReducedGBasis_KAX_plus(J)
  IsVERBOSE := IsVERBOSE_func("ReducedGBasis_KAX_plus");
  t0:=CpuTime();
  RGB_J := ReducedGBasis(J); /////// GitHub problem //// $.GB_function(J);
  ///  RGB_J := ReducedGBasis(J);
///    RGB_J := GBasisByHomog(J);
///  RGB_J := GBasis(J); /// controllare se si puo': Kalkbrener K1997?
  $.time_GB_AX := $.time_GB_AX + CpuTime() - t0;
  incr(ref $.count_GB_AX);
  if IsVERBOSE($.VL_base) then println "-- GB   done in K[A,X] ", TimeFrom(t0), "s"; endif;
  if IsVERBOSE($.VL_GB) then println "GB = ", RGB_J; endif;
  return RGB_J;
enddefine; -- ReducedGBasis_KAX_plus


define ReducedGBasis_KA_plus(J)
  if HasGBasis(J) then return ReducedGBasis(J); endif;
  IsVERBOSE := IsVERBOSE_func("ReducedGBasis_KA_plus");
  t0:=CpuTime();
  RGB_J := ReducedGBasis(J);
///  RGB_J := GBasis(J); /// controllare se si puo': Kalkbrener K1997?
  $.time_GB_A := $.time_GB_A + CpuTime() - t0;
  incr(ref $.count_GB_A);
  if IsVERBOSE($.VL_base) then println " -- GB_A done in K[A]"; endif;
  if IsVERBOSE($.VL_GB) then println "GB_A = ", RGB_J; endif;
  return RGB_J;
enddefine; -- ReducedGBasis_KA_plus


define IsEmptyDiffVanishing_plus(I, J)
  NoPrint := ReducedGBasis_KA_plus(I);
  t0:=CpuTime();
  b := IsEmptyDiffVanishing(I, J);
  $.time_IsEmptyDiffVanishing := $.time_IsEmptyDiffVanishing + CpuTime() - t0;
  incr(ref $.count_IsEmptyDiffVanishing);
  return b;
enddefine; -- IsEmptyDiffVanishing_plus


define IsContained_plus(I, J)
  t0:=CpuTime();
  b := IsContained(I, J);
  $.time_IsContained := $.time_IsContained + CpuTime() - t0;
  incr(ref $.count_IsContained);
  return b;
enddefine; -- IsContained_plus


define radical_plus(I)
  t0:=CpuTime();
  if type(I)=IDEAL then
    radI := radical(I);
    $.time_radical := $.time_radical + CpuTime() - t0;
    incr(ref $.count_radical);
    return radI;
  endif;
  r := radical(I);
  $.time_sqfr := $.time_sqfr + CpuTime() - t0;
  incr(ref $.count_sqfr);
  return r;
enddefine; -- radical_plus


define MBLPP_X_plus(G, ProdX)
  t0:=CpuTime();
  L := MBLPP_X(G, ProdX);
  $.time_MBLPP_X := $.time_MBLPP_X + CpuTime() - t0;
  incr(ref $.count_MBLPP_X);
  return L;
enddefine; -- MBLPP_X_plus


define ProdRad_plus(I, J)
  t0:=CpuTime();
  IJ := ProdRad(I,J);
  $.time_ProdRad := $.time_ProdRad + CpuTime() - t0;
  incr(ref $.count_ProdRad);
  return IJ;
enddefine; -- ProdRad_plus

  
