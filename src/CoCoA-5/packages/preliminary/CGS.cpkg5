define MinPolyZ(L, Params, Z)
  ProdNotZ := product(Params)/Z;
  PolyInZ := [ f in L | gcd(LT(f), ProdNotZ)=1 and gcd(LT(f), Z)=Z ];
  if PolyInZ = [] then return []; endif;
  MinDegZ := min([ deg(LT(f), Z) | f in PolyInZ]);
  return [ f in PolyInZ | deg(LT(f), Z) = MinDegZ ];
enddefine; -- MinPolyZ
  

define PrintSegments(CGS)
  AllX := CGS.X;
  if RingOf(CGS.I) <> RingOf(AllX[1]) then
    AllX := BringIn(RingOf(CGS.I), AllX);
  endif;
  K_AX := RingOf(AllX[1]);
//  CGS := CGS_fromCore(CGSC, AllX);
  foreach pippo in CGS.segments do
    println;
    print "for ";
    println pippo.IsNot0, " not 0";
    if not(IsZero(pippo.Is0)) then println "and ", gens(pippo.Is0), " = 0"; endif;
    println "  GB is "; indent(pippo.GB);
  endforeach;
enddefine; -- PrintSegments

  
define PrintCMinPoly(CGSC, AllX, Z)
  if RingOf(CGSC[1].GB[1]) <> RingOf(AllX[1]) then
    AllX := BringIn(RingOf(CGSC[1].GB[1]), AllX);
  endif;
  Z := last(AllX);
  -- make partial check -->
  if not(Z=min(AllX)) then error(sprint(Z)+" is not min of "+sprint(AllX)); endif;
  K_AX := RingOf(Z);
  if not(IsIndet(Z)) or not(Z isin AllX) then error("wrong indets"); endif;
  CGS := Pulisci(CGSC);
  foreach pippo in CGS do
    println;
    print "for ";
    println "not 0  ", pippo.IsNot0;
    if IsZero(pippo.Is0) then print "and "; endif;
//    if pippo.IsNot0<>[] then print "not 0 ", pippo.IsNot0, "  and "; endif;
    println " = 0  ", pippo.Is0;
    println "  minpoly is in ", MinPolyZ(pippo.GB, AllX, Z);
  endforeach;
enddefine; -- PrintCMinPoly


define SysIsIn(SYS, systems)
  D := RingOf(SYS.Is0);
  COD := RingOf(systems[1].Is0);
  phi := PolyAlgebraHom(D, COD, indets(COD));
  sys := record[IsNot0 := phi(SYS.IsNot0), Is0 := ideal(COD,phi(gens(SYS.Is0))), GB := phi(SYS.GB) ];
  foreach s in systems do
    if EqSet(sys.IsNot0, s.IsNot0) and sys.Is0 = s.Is0 and EqSet(sys.GB, s.GB) then
      return true;
    endif;
    endforeach;
    return false;
enddefine; -- SysIsIn

  
define CaseIsIn(C, cases)
  D := RingOf(C.Is0);
  COD := RingOf(cases[1].Is0);
  phi := PolyAlgebraHom(D, COD, indets(COD));
  c := record[IsNot0 := phi(C.IsNot0),
	      Is0  := ideal(COD, phi(gens(C.Is0))) ];
  foreach s in cases do
    if EqSet(c.IsNot0, s.IsNot0) and c.Is0 = s.Is0  then
      return true;
    endif;
  endforeach;
  return false;
enddefine; -- CaseIsIn

  
define CompareCGS(Systems1, Systems2)  
  Cases2 := [ record[IsNot0 := s.IsNot0, Is0 := s.Is0] | s in Systems2];
  return
  record[
	 NotInSyss1 := [ record[IsNot0 := s.IsNot0, Is0 := s.Is0]
			| s in Systems2 and not(SysIsIn(s,Systems1)) ],
	 NotInSyss2 := [ record[IsNot0 := s.IsNot0, Is0 := s.Is0]
			| s in Systems1 and not(SysIsIn(s,Systems2)) ],
	 NotInSyss2Colon := [ record[IsNot0 := s.IsNot0, Is0 := s.Is0]
			     | s in Systems1	 and
			     (s.IsNot0<>[] and
			      not(CaseIsIn(record[IsNot0 := s.IsNot0, Is0 := colon(s.Is0, ideal(product(s.IsNot0)))], Cases2))) ]
	 ];
enddefine; -- CompareCGS


define PulisciFinale(CGS)
  ResetGlobals();
  P := RingOf(CGS.I);
  K := CoeffRing(P);
  NewCGS := [];
  foreach X in CGS.segments do
    Is0 := radical_plus(X.Is0);
    IsNot0 := MakeSet([ radical_plus(I+X.Is0) | I in X.IsNot0]);
    GB := X.GB;
    -- if not(IsZero(Is0)) then
    --   if GB[1]<>1 then      print     RingOf(GB[1]), "  "; endif;
    --   println      RingOf(gens(Is0)[1]);
    --   GB:= ReducedGBasis(ideal(P,GB)+Is0);
    -- endif;
    if IsNot0=[] or not(IsEmptyDiffVanishing_plus(Is0, product(IsNot0))) then
      append(ref NewCGS, record[Is0 := Is0, IsNot0 := IsNot0, GB := GB]);
    endif;
  endforeach;
  PrintGlobals("-- ");
  return NewCGS;
enddefine; -- PulisciFinale


define ComputeSpecializedGB(I, OrdMat, ZeroCase)
  K_AX := RingOf(I); -- K[A,X];
  P := NewPolyRing(CoeffRing(K_AX), IndetSymbols(K_AX), OrdMat, 0);
  phi := PolyAlgebraHom(K_AX, P, indets(P));
  K_A := RingOf(ZeroCase); -- K[A,<X>];
  psi := PolyAlgebraHom(K_A, P, indets(P));
  I_P := ideal(phi(gens(I))) + ideal(psi(gens(ZeroCase)));
  ///+ ideal(P,[ phi(s[1]-s[2]) | s in SubstList]);
  return GBasis(I_P);
enddefine; -- ComputeSpecializedGB
  
  
