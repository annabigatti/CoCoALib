define CGSRecNabe(I,X, opt OrdMat)
  ResetGlobals();  
  -- I:ideal in K[A,X], X:list of variables
  K_AX := RingOf(I); -- K[A,X];
  if IsDefined(OrdMat) then
    P := NewPolyRing(CoeffRing(K_AX), IndetSymbols(K_AX), OrdMat, 0);
    phi := PolyAlgebraHom(K_AX, P, indets(P));
    result := record[X := phi(X), I := ideal(phi(gens(I)))];
    result.segments := CGSCoreNabe(ideal(P, []), ideal(one(P)),
				   result.I, product(result.X), 0);
  else
    CheckElimOrdering(K_AX, X);
    result := record[X := X, I := I];
    result.segments := CGSCoreNabe(ideal(K_AX,[]), ideal(one(K_AX)), result.I, product(result.X), 0);
  endif;
  PrintGlobals("N   ");
  return result;
enddefine; -- CGSRecNabe


  --== auxiliary ==--

define SprintRec(RecDepth)
  S := " ";
  for i:=1 to RecDepth do S := S+ "  "; endfor;
  return S + "rec " + sprint(RecDepth) + " on case(s)  ";
enddefine; -- SprintRec


define IsEmptyDiffVanishing(I, J)
  IsVERBOSE := IsVERBOSE_func("IsEmptyDiffVanishing");
  if IsVERBOSE($.VL_debug) then println "input J_nz = ",J, "   I_z = ",I; endif;
  foreach f in gens(J) do
////    println " ----> GBasis(I) =", GBasis(I), "  f=", f;
    if IsVERBOSE($.VL_debug) then println "  case f = ", f, "   I = ",I; endif;
//    if f isin I then continue; endif;  // 2023-12-05/2021-11-24 added this check in IsInRadical
    -- if IsVERBOSE($.VL_base) and f isin I then println " f is in I"; endif;
    -- if IsVERBOSE($.VL_base) and IsZeroDim(I) then println " I is 0-dim"; endif;
    if not(IsInRadical(f, I)) then return false; endif;
  endforeach;
  if IsVERBOSE($.VL_debug) then println "    --------> is empty"; endif;
  return true;
enddefine; -- IsEmptyDiffVanishing


